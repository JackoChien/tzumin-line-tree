let cur='m0';
function go(id){
  cur=id;
  document.querySelectorAll('.mp').forEach((p,i)=>{
    p.className='mp '+(Object.keys(D)[i]===id?'on':'off');
  });
  render(id);
}
function render(id){
  const pm=document.getElementById('pm');
  let html='';
  D[id].secs.forEach((s,si)=>{
    const sid='s'+id+si;
    html+=`<div class="sec">
      <div class="sh ${s.open?'open':''}" onclick="tog('${sid}')">
        <div class="sh-l"><div class="sh-name">${s.n}</div>${s.s?`<div class="sh-sub">${s.s}</div>`:''}</div>
        <span class="chev">▶</span>
      </div>
      <div class="kids ${s.open?'open':''}" id="${sid}">${s.h}</div>
    </div>`;
  });
  pm.innerHTML=html;
}
function tog(sid){
  const b=document.getElementById(sid),h=b.previousElementSibling,o=b.classList.contains('open');
  b.classList.toggle('open',!o);h.classList.toggle('open',!o);
}
function sit(id){
  ['a','b','c'].forEach(x=>{
    const p=document.getElementById('sit-'+x);
    if(p) p.className='sit-panel'+(x===id?' show':'');
  });
}
render('m0');
